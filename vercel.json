{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'Static site'",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/api/v1/generate", "destination": "/api/generate" },
    { "source": "/api/v1/artifact", "destination": "/api/artifact" },
    { "source": "/api/v1/equipment-types", "destination": "/api/v1/equipment_types" },
    { "source": "/api/v1/equipment-metadata", "destination": "/api/v1/equipment_metadata" },
    { "source": "/api/v1/site-context", "destination": "/api/v1/site_context" },
    { "source": "/api/v1/contextual-tag-descriptors", "destination": "/api/v1/contextual_tag_descriptors" },
    { "source": "/api/v1/equipment-controls", "destination": "/api/v1/equipment_controls" },
    { "source": "/api/v1/urs-library", "destination": "/api/v1/urs_library" },
    { "source": "/api/v1/frs-library", "destination": "/api/v1/frs_library" },
    { "source": "/api/v1/trs-library", "destination": "/api/v1/trs_library" },
    { "source": "/api/v1/hazard-context-options", "destination": "/api/v1/hazard_context_options" },
    { "source": "/api/v1/draft-docx", "destination": "/api/v1/draft_docx" }
  ],
  "env": {
    "ARTIFACT_BUCKET": "artifacts"
  }
}
