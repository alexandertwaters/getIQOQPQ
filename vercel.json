{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'Static site'",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/api/v1/generate", "destination": "/api/generate" },
    { "source": "/api/v1/artifact", "destination": "/api/artifact" },
    { "source": "/api/v1/equipment-types", "destination": "/api/v1/equipment_types" }
  ],
  "env": {
    "ARTIFACT_BUCKET": "artifacts"
  }
}
