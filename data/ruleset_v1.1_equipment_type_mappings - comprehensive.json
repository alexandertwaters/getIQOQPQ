    {
      "ruleId": "R_MAP_FACILITIES_UTILITIES_V1_1",
      "name": "Facilities and utilities cross-cutting mappings",
      "trigger": "after R_MAP_DECONTAMINATION_ASSEMBLY_V1_1",
      "logic": [
        {
          "if": "siteContext.utilities contains 'WFI'",
          "then": {
            "addTests": {
              "OQ": [
                {"id":"OQ_WFI_01","title":"WFI loop integrity and conductivity verification","params":{}}
              ],
              "PQ": [
                {"id":"PQ_WFI_01","title":"WFI distribution loop microbial challenge and recovery","params":{}}
              ]
            },
            "rationale": "WFI presence requires WFI loop verification in OQ/PQ"
          }
        },
        {
          "if": "siteContext.utilities contains 'Vacuum'",
          "then": {
            "addTests": {
              "OQ": [
                {"id":"OQ_VAC_01","title":"Vacuum pump performance and leak test","params":{}}
              ],
              "PQ": [
                {"id":"PQ_VAC_01","title":"Vacuum performance under load","params":{}}
              ]
            },
            "rationale": "Vacuum-dependent equipment requires vacuum verification"
          }
        },
        {
          "if": "siteContext.utilities contains 'Instrument Air' or siteContext.utilities contains 'Compressed Air'",
          "then": {
            "addTests": {
              "OQ": [
                {"id":"OQ_AIR_01","title":"Instrument air dew point and particle verification","params":{}}
              ],
              "PQ": [
                {"id":"PQ_AIR_01","title":"Air quality verification under operational load","params":{}}
              ]
            },
            "rationale": "Compressed/instrument air quality affects many process controls"
          }
        },
        {
          "if": "siteContext.cleanroomClass in ['ISO 1','ISO 2','ISO 3','ISO 4','ISO 5'] and equipment.siteContext.productContact == true",
          "then": {
            "addTests": {
              "PQ": [
                {"id":"PQ_CLEAN_01","title":"Operational particle mapping and microbiological sampling","params":{"method":"ISO 14644-1 mapping","sampleCount":"per standard"}}
              ]
            },
            "rationale": "High-class cleanrooms with product contact require particle and microbiological verification"
          }
        },
        {
          "if": "siteContext.productionThroughput == 'High' and qualificationBand in ['Targeted','Full']",
          "then": {
            "modifyTests": {
              "PQ": {"increaseSampleCountByFactor": 2}
            },
            "rationale": "High throughput increases PQ sampling requirements"
          }
        },
        {
          "if": "controlArchitecture contains 'Computerized' and controlArchitecture contains 'electronic records'",
          "then": {
            "addTests": {
              "IQ": [
                {"id":"IQ_CSV_01","title":"Record software baseline and configuration","params":{}}
              ],
              "OQ": [
                {"id":"OQ_CSV_01","title":"Audit trail and backup/restore verification","params":{}}
              ],
              "PQ": [
                {"id":"PQ_CSV_01","title":"Longitudinal audit trail review during PQ","params":{}}
              ]
            },
            "rationale": "Computerized systems with electronic records require CSV/CSV-like verification"
          }
        }
      ],
      "standards": ["ISO 14644","ISO 8573","USP <1231>","21 CFR 820"]
    },

    {
      "ruleId": "R_FALLBACK_AND_METADATA_V1_1",
      "name": "Fallbacks, standards propagation, and metadata enrichment",
      "trigger": "after all mapping rules",
      "logic": [
        {
          "action": "propagateStandards",
          "details": "If a hazard's mapping block includes 'standards', ensure those standards are attached to the package-level standards list and to the hazard mapping output."
        },
        {
          "action": "ensureStructuredOutputs",
          "details": "Convert free-text IQ/OQ/PQ lists into structured objects with id/title/params. If only free-text exists, wrap into structured object with generated id."
        },
        {
          "action": "fallbackMapping",
          "details": "If no explicit mapping exists for a hazard.ruleId, attach the qualificationBand-level IQ/OQ/PQ templates and mark mapping as 'inferred' with rationale 'no explicit equipment-type mapping; used band fallback'."
        },
        {
          "action": "fingerprintPolicy",
          "details": "Fingerprint includes: hazardId, selected labels, numeric mapped values, ruleId, qualificationBand, IQ/OQ/PQ ids and testParameters. Exclude freeform 'help' and 'example' text from fingerprint to avoid editorial churn."
        }
      ],
      "standards": ["ISO 14971","21 CFR 820"]
    }
  ]
}

