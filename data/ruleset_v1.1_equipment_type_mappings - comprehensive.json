  "rulesetId": "ruleset_v1.1",
  "generatedAt": "2026-03-10T20:00:00Z",
  "description": "Comprehensive deterministic ruleset mapping hazards and qualification bands to structured IQ/OQ/PQ templates. Includes cross-cutting rules for utilities, cleanroom class, product contact, throughput, and control architecture.",
  "rules": [
    {
      "ruleId": "R_SCORE_ISO14971_V1_1",
      "name": "Compute per-hazard risk and Residual Risk Index",
      "trigger": "after hazard attribute selection",
      "logic": [
        {
          "action": "mapNumericValues",
          "details": "Map Severity/Probability/Exposure/Detectability/ControlEffectiveness option labels to numeric values using canonical mapping table."
        },
        {
          "action": "computePerHazard",
          "expressions": {
            "RawRisk": "Severity * ProbabilityOfOccurrence",
            "AdjustedRisk": "RawRisk * Exposure * (1 - Detectability)",
            "ResidualRisk": "AdjustedRisk * ControlEffectiveness"
          }
        },
        {
          "action": "policyEscalations",
          "rules": [
            {
              "if": "exists hazard where hazard.ruleId startsWith 'R_STER' and Severity_label == 'Catastrophic' and equipment.siteContext.productContact == true",
              "then": "set hazard.EscalatedResidualRiskForMapping = hazard.ResidualRisk * 10",
              "rationale": "Conservative escalation for catastrophic sterilization hazards affecting product contact"
            },
            {
              "if": "exists hazard where hazard.ruleId startsWith 'R_PKG' and equipment.siteContext.productContact == true and Severity_label in ['Catastrophic','Major']",
              "then": "set hazard.EscalatedResidualRiskForMapping = hazard.ResidualRisk * 3",
              "rationale": "Elevate packaging hazards that contact product"
            },
            {
              "if": "exists hazard where hazard.ruleId startsWith 'R_ANA' and controlArchitecture contains 'Computerized' and controlArchitecture contains 'electronic records'",
              "then": "set hazard.EscalatedResidualRiskForMapping = hazard.ResidualRisk * 2",
              "rationale": "Elevate analytical hazards when computerized systems with electronic records are present"
            },
            {
              "if": "equipmentType == 'HVAC Air Handling Unit serving cleanrooms' and siteContext.cleanroomClass in ['ISO 1','ISO 2','ISO 3','ISO 4','ISO 5','ISO 6','ISO 7']",
              "then": "increase Exposure by 0.2 for hazards affecting cleanroom performance",
              "rationale": "Multiple-zone effect increases exposure for HVAC hazards in higher-class cleanrooms"
            }
          ]
        },
        {
          "action": "aggregate",
          "expression": "ResidualRiskIndex = max(hazard.EscalatedResidualRiskForMapping if present else hazard.ResidualRisk) + 0.1 * sum(hazard.EscalatedResidualRiskForMapping if present else hazard.ResidualRisk)"
        },
        {
          "action": "mapQualificationBand",
          "conditions": [
            {"if": "ResidualRiskIndex <= 0.15", "then": {"qualificationBand": "Basic", "qualificationDepth": "Installation Qualification + basic Operational Qualification"}},
            {"if": "ResidualRiskIndex > 0.15 && ResidualRiskIndex <= 0.40", "then": {"qualificationBand": "Targeted", "qualificationDepth": "Installation Qualification + Operational Qualification + targeted Performance Qualification"}},
            {"if": "ResidualRiskIndex > 0.40", "then": {"qualificationBand": "Full", "qualificationDepth": "Full Installation Qualification + Operational Qualification + Performance Qualification with microbiological verification where applicable"}}
          ]
        }
      ],
      "standards": ["ISO 14971", "ISO 17665", "ISO 14644", "GAMP 5", "21 CFR 820"]
    },

